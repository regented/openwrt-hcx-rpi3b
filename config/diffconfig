# OpenWrt diffconfig for RPi3B+ with hcxdumptool/hcxtools
# Apply with: cp diffconfig .config && make defconfig

# Target
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2710=y
CONFIG_TARGET_bcm27xx_bcm2710_DEVICE_rpi-3-b-plus=y

# Use ext4 for easier post-flash modification
CONFIG_TARGET_ROOTFS_EXT4=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set

# SSL: OpenSSL (not mbedTLS)
CONFIG_PACKAGE_libopenssl=y
CONFIG_OPENSSL_WITH_ASM=y
CONFIG_OPENSSL_WITH_DEPRECATED=y
CONFIG_OPENSSL_WITH_PSK=y

# SSH: OpenSSH (not dropbear)
CONFIG_PACKAGE_openssh-server=y
CONFIG_PACKAGE_openssh-sftp-server=y
# CONFIG_PACKAGE_dropbear is not set

# WiFi: hostapd with OpenSSL
CONFIG_PACKAGE_hostapd-openssl=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_wireless-tools=y

# Kernel modules: internal WiFi
CONFIG_PACKAGE_kmod-brcmfmac=y
CONFIG_PACKAGE_brcmfmac-firmware-43430-sdio=y
CONFIG_PACKAGE_brcmfmac-firmware-43455-sdio=y

# Kernel modules: external MT7601U USB WiFi
CONFIG_PACKAGE_kmod-mt7601u=y

# Kernel modules: USB
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-dwc2=y

# Capture tools
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_libpcap=y

# Custom packages
CONFIG_PACKAGE_hcxdumptool=y
CONFIG_PACKAGE_hcxtools=y

# Network services
CONFIG_PACKAGE_dnsmasq=y

# Strip unnecessary packages
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_ip6tables is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
# CONFIG_PACKAGE_luci is not set
