# ============================================================================
# OpenWrt minimal .config for Raspberry Pi 3B+ with hcxdumptool/hcxtools
# Apply: cp config/.config ~/openwrt-src/.config && cd ~/openwrt-src && make defconfig
# ============================================================================

# --- Target Platform: Raspberry Pi 3B+ (BCM2710, aarch64_cortex-a53) -------
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2710=y
CONFIG_TARGET_bcm27xx_bcm2710_DEVICE_rpi-3=y

# --- Root filesystem: ext4 for easier post-flash modification ---------------
CONFIG_TARGET_ROOTFS_EXT4=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set

# --- SSL/TLS: Full OpenSSL (required by openssh, hostapd, hcxtools) ---------
CONFIG_PACKAGE_libopenssl=y
CONFIG_OPENSSL_WITH_ASM=y
CONFIG_OPENSSL_WITH_DEPRECATED=y
CONFIG_OPENSSL_WITH_PSK=y
CONFIG_PACKAGE_openssl-util=y

# --- SSH: OpenSSH server (NOT dropbear) -------------------------------------
# dropbear conflicts with openssh-server on port 22; explicitly disable it
CONFIG_PACKAGE_openssh-server=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssh-keygen=y
# CONFIG_PACKAGE_dropbear is not set

# --- WiFi AP: hostapd with OpenSSL backend ----------------------------------
# hostapd-openssl runs the WPA2-PSK AP on wlan0 (internal brcmfmac)
# wpad-basic-mbedtls is the default; disable it to avoid conflicts
CONFIG_PACKAGE_hostapd-openssl=y
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set

# --- WiFi utilities ---------------------------------------------------------
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wireless-tools=y

# --- Kernel modules: Internal WiFi (Broadcom brcmfmac on wlan0) ------------
CONFIG_PACKAGE_kmod-brcmfmac=y
CONFIG_PACKAGE_brcmfmac-firmware-43430-sdio=y
CONFIG_PACKAGE_brcmfmac-firmware-43455-sdio=y

# --- Kernel modules: External USB WiFi (MT7601U on wlan1) ------------------
CONFIG_PACKAGE_kmod-mt7601u=y

# --- Kernel modules: WiFi stack (pulled by kmod-brcmfmac/kmod-mt7601u) -----
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y

# --- Kernel modules: USB (required for MT7601U adapter) ---------------------
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-dwc2=y

# --- Capture & analysis tools -----------------------------------------------
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_libpcap=y

# --- Custom packages: hcxdumptool + hcxtools (from local feed) -------------
CONFIG_PACKAGE_hcxdumptool=y
CONFIG_PACKAGE_hcxtools=y

# --- Network services -------------------------------------------------------
# dnsmasq provides DHCP for AP clients connecting via wlan0
CONFIG_PACKAGE_dnsmasq=y

# --- Usability: shell & editor ----------------------------------------------
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_nano=y

# --- Networking utilities ----------------------------------------------------
CONFIG_PACKAGE_ip-full=y

# --- IPv6: Disable to save space (not needed for this build) ----------------
# CONFIG_IPV6 is not set
# CONFIG_PACKAGE_ip6tables is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
# CONFIG_KERNEL_IPV6 is not set

# --- Packages to EXCLUDE (size optimization) --------------------------------
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_luci is not set
# CONFIG_PACKAGE_luci-ssl is not set
